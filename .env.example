# ============================================
# AppHostFast Configuration
# ============================================

# Application
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/apphostfast

# Redis Cache & Queue
REDIS_URL=redis://localhost:6379

# GitHub OAuth
# Create OAuth app at: https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_WEBHOOK_SECRET=your_webhook_secret

# JWT / Session
JWT_SECRET=your_jwt_secret_key_min_32_chars

# Docker Engine Configuration
DOCKER_HOST=unix:///var/run/docker.sock
DOCKER_REGISTRY_URL=registry.apphostfast.dev
DOCKER_REGISTRY_USERNAME=apphostfast
DOCKER_REGISTRY_PASSWORD=registry_password

# SSL Configuration (Let's Encrypt)
LE_EMAIL=admin@apphostfast.dev
LE_PRODUCTION=false

# Traefik Reverse Proxy
TRAEFIK_DASHBOARD_URL=traefik.apphostfast.dev
TRAEFIK_DASHBOARD_PASSWORD=admin

# Stripe (Payment Processing)
STRIPE_SECRET_KEY=sk_test_your_stripe_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Logging
LOG_LEVEL=info
LOKI_URL=http://localhost:3100

# Email Service (for notifications)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@apphostfast.dev
SMTP_PASSWORD=your_email_password
SMTP_FROM=AppHostFast <noreply@apphostfast.dev>

# Monitoring & Analytics
SENTRY_DSN=
POSTHOG_API_KEY=

# Feature Flags
ENABLE_WORDPRESS_DEPLOYMENTS=true
ENABLE_PHP_SUPPORT=true
ENABLE_POWER_BOOST=true
ENABLE_CUSTOM_DOMAINS=true
ENABLE_DATABASE_BACKUPS=true
